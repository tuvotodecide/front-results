{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "middleware.ts",
    "src/**/*.d.ts",
    "src/app/**/*.ts",
    "src/app/**/*.tsx",
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
    "src/domains/**/*.ts",
    "src/domains/**/*.tsx",
    "src/features/**/*.ts",
    "src/features/**/*.tsx",
    "src/hooks/**/*.ts",
    "src/hooks/**/*.tsx",
    "src/shared/**/*.d.ts",
    "src/shared/**/*.ts",
    "src/shared/**/*.tsx",
    "src/store/**/*.ts",
    "src/store/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "src/legacy-pages/**/*",
    "src/main.tsx",
    "src/App.tsx",
    "src/Router.tsx"
  ]
}
