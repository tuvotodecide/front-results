{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "src/app/**/*.ts",
    "src/app/**/*.tsx",
    "src/domains/**/*.ts",
    "src/domains/**/*.tsx",
    "src/shared/**/*.d.ts",
    "src/shared/**/*.ts",
    "src/shared/**/*.tsx",
    "src/store/index.ts",
    "src/store/rootReducer.ts",
    "src/store/listeners.ts",
    "src/store/apiSlice.ts",
    "src/store/auth/authSlice.ts",
    "src/store/election/electionSlice.ts",
    "src/store/recintos/recintosSlice.ts",
    "src/store/departments/departmentsSlice.ts",
    "src/store/resultados/resultadosSlice.ts",
    "src/store/electoralLocations/electoralLocationsSlice.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
