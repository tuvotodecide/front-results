{
    "compilerOptions": {
        "target": "ES2020",
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "types": [
            "cypress",
            "node"
        ],
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "isolatedModules": true
    },
    "include": [
        "**/*.ts",
        "**/*.d.ts"
    ]
}