{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["ES2023", "DOM"],
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["node", "cypress"]
  },
  "include": [
    "cypress.config.ts",
    "cypress/support/**/*.ts",
    "cypress/e2e/smoke/**/*.ts",
    "cypress/e2e/smoke/**/*.tsx"
  ],
  "exclude": [
    "cypress/legacy/**",
    "cypress/staging/**"
  ]
}
