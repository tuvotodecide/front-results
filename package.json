{
  "name": "yocustodio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:next": "next dev",
    "dev:legacy": "vite",
    "build": "next build",
    "build:next": "next build",
    "build:legacy": "tsc -b && vite build",
    "start": "next start",
    "start:next": "next start",
    "preview:legacy": "vite preview",
    "typecheck": "pnpm typecheck:app && pnpm typecheck:tests",
    "typecheck:app": "tsc -p tsconfig.next.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.tests.json --noEmit",
    "typecheck:cypress": "tsc -p tsconfig.cypress.json --noEmit",
    "typecheck:legacy": "tsc -p tsconfig.app.json --noEmit",
    "lint": "eslint src/app src/domains src/shared src/components src/hooks src/store src/features tests middleware.ts --max-warnings=0",
    "lint:cypress": "eslint cypress cypress.config.ts --max-warnings=0",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "check:dependencies": "vitest run tests/integration/dependency-checks.test.ts",
    "metrics:frontend": "node tools/ci/frontend-metrics.mjs",
    "validate:frontend": "pnpm lint && pnpm typecheck && pnpm test:unit && pnpm test:integration && pnpm test:coverage && pnpm build && pnpm check:dependencies",
    "quality:ci": "pnpm validate:frontend",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test:e2e": "cypress run"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@reduxjs/toolkit": "^2.12.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-table": "^8.21.3",
    "@types/react-redux": "^7.1.34",
    "crypto": "^1.0.1",
    "d3": "^7.9.0",
    "formik": "^2.4.9",
    "fuse.js": "^7.3.0",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.525.0",
    "next": "15.5.14",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-modal": "^3.16.3",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.15.1",
    "react-select": "^5.10.2",
    "uuid": "^13.0.2",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-modal": "^3.16.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "@vitest/coverage-v8": "^3.2.4",
    "cypress": "^15.15.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "jsdom": "^26.1.0",
    "postcss": "8.4.31",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.4.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
