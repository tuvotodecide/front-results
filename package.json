{
  "name": "yocustodio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:next": "next dev",
    "dev:legacy": "vite",
    "build": "next build",
    "build:next": "next build",
    "build:legacy": "tsc -b && vite build",
    "start": "next start",
    "start:next": "next start",
    "preview:legacy": "vite preview",
    "typecheck": "pnpm typecheck:app && pnpm typecheck:tests",
    "typecheck:app": "next typegen && tsc -p tsconfig.next.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.tests.json --noEmit",
    "typecheck:cypress": "tsc -p tsconfig.cypress.json --noEmit",
    "typecheck:legacy": "tsc -p tsconfig.app.json --noEmit",
    "lint": "eslint src/app src/domains src/shared src/components src/hooks src/store src/features tests middleware.ts --max-warnings=0",
    "lint:cypress": "eslint cypress.config.ts cypress/support cypress/e2e/smoke --max-warnings=0",
    "check:no-focused-tests": "node tools/ci/check-active-test-focus.mjs",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:flow:auth-permissions": "vitest run tests/unit/auth-context.test.ts tests/unit/auth-resultados.validation.test.ts tests/unit/auth-roles-navigation.test.ts tests/unit/middleware.test.ts tests/unit/register-prefill.test.ts tests/unit/resolve-auth-resultados-redirect.test.ts tests/integration/auth-domain-password-pages.test.tsx tests/integration/auth-resultados-pages.test.tsx tests/integration/resultados-private-guard.test.tsx tests/integration/votacion-private-guard.test.tsx tests/integration/roles-permissions-navigation.test.tsx",
    "test:flow:approvals": "vitest run tests/integration/access-approvals.test.tsx",
    "test:flow:election-management": "vitest run tests/unit/election-configuration-cd.test.tsx tests/unit/referendum-flow.test.tsx tests/unit/election-render-utils.test.ts tests/unit/create-news-modal.test.tsx tests/integration/election-config-cd-flow.test.tsx tests/integration/election-config-components.test.tsx",
    "test:flow:padron-publication": "vitest run tests/unit/padron-parser.test.ts tests/unit/padron-gemini-observations.test.ts tests/unit/padron-participation-check.test.tsx tests/unit/padron-ux.test.tsx tests/unit/use-election-publish.test.tsx tests/unit/election-publication-ux.test.tsx tests/integration/election-padron-flow.test.tsx",
    "test:flow:results-reports": "vitest run tests/unit/capture-element-as-png.test.ts tests/unit/kiosk-constants.test.ts tests/unit/past-elections-page.test.tsx tests/unit/public-landing-repository.test.ts tests/unit/participation-analytics-modal.test.tsx tests/unit/voting-events-participation-api.test.ts tests/unit/request-error-message.test.ts tests/unit/runtime-failure-reporting.test.ts tests/integration/resultados-reports-audit.test.tsx tests/integration/table-search-pagination.test.tsx tests/integration/participation-analytics-flow.test.tsx tests/integration/dependency-checks.test.ts",
    "test:coverage": "vitest run --coverage",
    "check:dependencies": "vitest run tests/integration/dependency-checks.test.ts",
    "metrics:frontend": "node tools/ci/frontend-metrics.mjs",
    "validate:frontend": "pnpm lint && pnpm typecheck && pnpm test:unit && pnpm test:integration && pnpm test:coverage && pnpm build && pnpm check:dependencies",
    "quality:ci": "pnpm validate:frontend",
    "cypress:verify": "node tools/ci/run-cypress.mjs verify",
    "cy:open": "node tools/ci/run-cypress.mjs open",
    "cy:run": "node tools/ci/run-cypress.mjs run",
    "test:e2e": "node tools/ci/run-cypress.mjs run",
    "test:cypress:smoke": "node tools/ci/run-cypress.mjs run --browser electron --spec cypress/e2e/smoke/**/*.cy.ts",
    "test:cypress:staging": "node tools/ci/run-cypress.mjs run --browser electron --spec cypress/staging/**/*.cy.ts"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1075.0",
    "@heroicons/react": "^2.2.0",
    "@reduxjs/toolkit": "^2.12.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-table": "^8.21.3",
    "@types/react-redux": "^7.1.34",
    "crypto": "^1.0.1",
    "d3": "^7.9.0",
    "formik": "^2.4.9",
    "fuse.js": "^7.3.0",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.525.0",
    "next": "15.5.14",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-modal": "^3.16.3",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.15.1",
    "react-select": "^5.10.2",
    "uuid": "^13.0.2",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-modal": "^3.16.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "@vitest/coverage-v8": "^3.2.4",
    "cypress": "15.15.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "jsdom": "^26.1.0",
    "postcss": "8.4.31",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.4.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
