{
  "name": "yocustodio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:next": "next dev",
    "dev:legacy": "vite",
    "build": "next build",
    "build:next": "next build",
    "build:legacy": "tsc -b && vite build",
    "start": "next start",
    "start:next": "next start",
    "preview:legacy": "vite preview",
    "typecheck": "npm run typecheck:app && npm run typecheck:tests",
    "typecheck:app": "tsc -p tsconfig.next.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.tests.json --noEmit",
    "typecheck:cypress": "tsc -p tsconfig.cypress.json --noEmit",
    "typecheck:legacy": "tsc -p tsconfig.app.json --noEmit",
    "lint": "eslint src/app src/domains src/shared src/components src/hooks src/store src/features tests middleware.ts --max-warnings=0",
    "lint:cypress": "eslint cypress cypress.config.ts --max-warnings=0",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "quality:ci": "npm run lint && npm run typecheck && npm run test:unit && npm run test:integration && npm run build",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test:e2e": "cypress run"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@reduxjs/toolkit": "^2.6.1",
    "@tailwindcss/vite": "^4.0.15",
    "@tanstack/react-table": "^8.21.3",
    "@types/react-redux": "^7.1.34",
    "crypto": "^1.0.1",
    "d3": "^7.9.0",
    "ethers": "^6.16.0",
    "formik": "^2.4.6",
    "fuse.js": "^7.1.0",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.525.0",
    "next": "15.5.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "react-modal": "^3.16.3",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.4.0",
    "react-select": "^5.10.2",
    "uuid": "^13.0.0",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@tailwindcss/postcss": "4.2.2",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.13.11",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/react-modal": "^3.16.3",
    "@types/react-router-dom": "^5.3.3",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "cypress": "^15.12.0",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "jsdom": "^26.1.0",
    "postcss": "8.4.31",
    "tailwindcss": "^4.1.4",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
